---
import { getCollection } from 'astro:content';
import MainLayout from '../layouts/MainLayout.astro';
import LandingHero from '../components/LandingHero.astro';
import { Client } from '@notionhq/client';

const ADMIN_SECRET = process.env.ADMIN_SECRET || import.meta.env.ADMIN_SECRET || 'ss_alpha_2026_distributor';
const url = new URL(Astro.request.url);
const providedKey = url.searchParams.get('key');
const isAdmin = providedKey === ADMIN_SECRET;
const cookiePassport = Astro.cookies.get('ss_alpha_passport')?.value;
const isUnlocked = cookiePassport === 'unlocked_2026';

const products = await getCollection('products') || [];
const productsWithImages = products.filter(p => p.data.image && p.data.image.length > 5);

// Vault Data (Custodians)
const vaultCategories = [...new Set(productsWithImages.map(p => p.data.category?.[0] || 'ESSENTIAL'))].sort();
const vaultMap = vaultCategories.map(cat => ({
	name: cat,
	nodes: productsWithImages.filter(p => p.data.category?.[0] === cat)
}));

// Helper for dynamic signal meter
const getSignalData = (score: number, status: string) => {
	const activeBars = score >= 7 ? 3 : (score >= 4 ? 2 : 1);
	const color = status === 'Live' ? '#00ff88' : '#ff4444';
	return { activeBars, color };
};
---

<MainLayout title="SelectStream | Spatial Laboratory">
	<div id="unlocked-header" style={isUnlocked ? "display: block" : "display: none"}>
		<section class="lab-dashboard">
			<h1>SOVEREIGN_CANVAS_v1.8</h1>
			<p class="admin-subtitle">LABORATORY ACTIVE • SPATIAL_CURATION_MODE</p>
		</section>
	</div>
	
	<div id="locked-header" style={!isUnlocked ? "display: block" : "display: none"}>
		<LandingHero />
	</div>

	<div class="spatial-canvas" id="canvas">
		{/* THE DOCK: Adding Vaults */}
		<div class="vault-dock">
			<span class="dock-label">VAULT_DOCK</span>
			<div class="dock-controls">
				{vaultMap.map((v, i) => (
					<button class="dock-item add-vault-trigger" data-vault={JSON.stringify(v)}>
						{String(i + 1).padStart(2, '0')}_{v.name.toUpperCase()}
					</button>
				))}
			</div>
		</div>

		{/* THE WORKSPACE: Elements appear here */}
		<div class="workspace-area" id="workspace">
			<div class="canvas-empty-state" id="empty-state">
				<p>CANVAS_NULL. ENGAGE VAULT FROM DOCK TO INITIALIZE CURATION.</p>
			</div>
		</div>
	</div>
</MainLayout>

<script>
	const initSpatialUI = () => {
		const workspace = document.getElementById('workspace');
		const emptyState = document.getElementById('empty-state');
		const haptic = (ms = 10) => { if ('vibrate' in navigator) navigator.vibrate(ms); };

		// Template for a Spun-up Node Card
		const createNodeHTML = (product: any, isStacked = false) => {
			const signal = (product.trendScore >= 7 ? 3 : (product.trendScore >= 4 ? 2 : 1));
			const barColor = '#00ff88';

			return `
				<div class="node-card ${isStacked ? 'stacked-node' : 'active-node'}">
					<div class="card-flipper">
						<div class="minimal-card card-face card-front">
							<div class="visual-viewport">
								<img src="${product.image}" alt="${product.title}" />
							</div>
							<div class="card-meta-container">
								<div class="card-meta">
									<span class="diagnostic-tag">[${product.painPoint?.toUpperCase() || 'CORE_NODE'}]</span>
									<h3>${product.title}</h3>
								</div>
								<div class="analytics-footer">
									<div class="signal-group">
										<div class="signal-meter">
											${[1,2,3].map(b => `<div class="signal-bar ${b <= signal ? 'active' : ''}" style="${b <= signal ? `--bar-color: ${barColor}` : ''}"></div>`).join('')}
										</div>
										<span class="score-value">${product.trendScore.toFixed(1)}</span>
									</div>
									<div class="action-group">
										<button class="card-action flip-trigger" title="Technical Specs">
											<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4M12 8h.01"/></svg>
										</button>
										<button class="card-action stack-trigger" title="Engage Signal / Magnet" data-node='${JSON.stringify(product)}'>
											<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
												<path d="M5 12V3m0 9l-2-2m2 2l2-2"/>
												<path d="M19 12V3m0 9l-2-2m2 2l2-2"/>
												<path d="M12 21V10m0 11l-3-3m3 3l3-3"/>
											</svg>
										</button>
										${isStacked ? `<button class="card-action remove-node">&times;</button>` : ''}
									</div>
								</div>
							</div>
						</div>
						<div class="minimal-card card-face card-back">
							<div class="blueprint-header">
								<span class="bp-label">TECHNICAL_SPEC</span>
								<button class="card-action flip-trigger">&times;</button>
							</div>
							<div class="blueprint-body">
								<div class="spec-row"><span class="label">ID</span><span class="val">${product.slug}</span></div>
								<div class="spec-row"><span class="label">HYBRID</span><span class="val">${product.digitalStack || 'NONE'}</span></div>
								<div class="blueprint-graph"><div class="grid-mesh"></div><p>${product.notes || 'No lab notes.'}</p></div>
							</div>
							<a href="${product.buyLink}" target="_blank" class="buy-link-back">CHECK_AMAZON_PRICE</a>
						</div>
					</div>
				</div>
			`;
		};

		// 1. Adding a Vault to Canvas
		document.querySelectorAll('.add-vault-trigger').forEach(btn => {
			btn.addEventListener('click', () => {
				haptic(15);
				if (emptyState) emptyState.style.display = 'none';
				const vaultData = JSON.parse(btn.getAttribute('data-vault') || '{}');
				
				// Create Vault Portal
				const vaultEl = document.createElement('div');
				vaultEl.className = 'vault-portal';
				vaultEl.innerHTML = `
					<div class="vault-inner">
						<span class="vault-id">VAULT_${vaultData.name.toUpperCase()}</span>
						<div class="vault-info-overlay">
							<p>CUSTODIAN OF ${vaultData.nodes.length} NODES</p>
							<span class="sub">CLICK TO SPIN INTERFACE</span>
						</div>
					</div>
					<button class="close-vault">&times;</button>
				`;

				// CLICK: Spin up the Node Card
				vaultEl.addEventListener('click', (e) => {
					if ((e.target as HTMLElement).classList.contains('close-vault')) return;
					haptic(20);
					
					// Remove existing active node for this vault if any
					vaultEl.querySelector('.active-node')?.remove();
					
					const firstProduct = vaultData.nodes[0].data;
					const nodeCard = document.createElement('div');
					nodeCard.className = 'node-spin-container';
					nodeCard.innerHTML = createNodeHTML({
						...firstProduct,
						image: firstProduct.image,
						trendScore: firstProduct.trendScore,
						painPoint: firstProduct.painPoint,
						notes: firstProduct.notes,
						buyLink: firstProduct.buyLink,
						slug: firstProduct.slug,
						id: vaultData.nodes[0].id
					});

					// Logic to cycle through items
					let currentIndex = 0;
					nodeCard.addEventListener('wheel', (e) => {
						e.preventDefault();
						currentIndex = (e.deltaY > 0) ? (currentIndex + 1) % vaultData.nodes.length : (currentIndex - 1 + vaultData.nodes.length) % vaultData.nodes.length;
						const p = vaultData.nodes[currentIndex].data;
						nodeCard.innerHTML = createNodeHTML({
							...p, id: vaultData.nodes[currentIndex].id
						});
						attachNodeListeners(nodeCard);
					}, { passive: false });

					vaultEl.appendChild(nodeCard);
					attachNodeListeners(nodeCard);
				});

				workspace?.appendChild(vaultEl);
				
				vaultEl.querySelector('.close-vault')?.addEventListener('click', () => {
					vaultEl.remove();
					if (workspace?.children.length === 1) if (emptyState) emptyState.style.display = 'block';
				});
			});
		});

		const attachNodeListeners = (container: HTMLElement) => {
			// Flip
			container.querySelectorAll('.flip-trigger').forEach(b => {
				b.addEventListener('click', (e) => {
					e.stopPropagation();
					container.querySelector('.node-card')?.classList.toggle('is-flipped');
				});
			});

			// Stack (Magnet/Antenna)
			container.querySelectorAll('.stack-trigger').forEach(b => {
				b.addEventListener('click', (e) => {
					e.stopPropagation();
					haptic(30);
					const nodeData = JSON.parse(b.getAttribute('data-node') || '{}');
					
					// Create persistent card on canvas
					const stackedCard = document.createElement('div');
					stackedCard.className = 'stacked-card-anchor';
					stackedCard.innerHTML = createNodeHTML(nodeData, true);
					
					workspace?.appendChild(stackedCard);
					
					stackedCard.querySelector('.remove-node')?.addEventListener('click', () => stackedCard.remove());
					stackedCard.querySelector('.flip-trigger')?.addEventListener('click', () => {
						stackedCard.querySelector('.node-card')?.classList.toggle('is-flipped');
					});
				});
			});
		};
	};

	initSpatialUI();
	document.addEventListener('astro:after-swap', initSpatialUI);
</script>

<style>
	.spatial-canvas {
		position: relative;
		width: 100%;
		height: 80vh;
		background: radial-gradient(circle at center, #050505 0%, #000 100%);
		border: 1px solid #111;
		border-radius: 4px;
		overflow: hidden;
		margin-top: 2rem;
	}

	/* THE DOCK */
	.vault-dock {
		position: absolute;
		bottom: 2rem;
		left: 50%;
		transform: translateX(-50%);
		background: rgba(8,8,8,0.8);
		backdrop-filter: blur(20px);
		border: 1px solid #222;
		padding: 1rem 2rem;
		border-radius: 100px;
		display: flex;
		align-items: center;
		gap: 2rem;
		z-index: 1000;
	}

	.dock-label { font-family: var(--family-mono); font-size: 0.45rem; color: #444; letter-spacing: 0.2rem; }
	.dock-controls { display: flex; gap: 1rem; }
	
	.dock-item {
		background: none;
		border: 1px solid #222;
		color: #888;
		padding: 0.5rem 1rem;
		border-radius: 100px;
		font-family: var(--family-mono);
		font-size: 0.55rem;
		cursor: pointer;
		transition: all 0.3s ease;
	}
	.dock-item:hover { color: #fff; border-color: #444; background: #111; }

	/* WORKSPACE */
	.workspace-area {
		width: 100%;
		height: 100%;
		padding: 4rem;
		display: flex;
		flex-wrap: wrap;
		gap: 6rem;
		align-items: flex-start;
		justify-content: center;
	}

	.canvas-empty-state {
		position: absolute;
		top: 50%;
		left: 50%;
		transform: translate(-50%, -50%);
		color: #111;
		font-family: var(--family-mono);
		font-size: 0.6rem;
		letter-spacing: 0.5rem;
		text-align: center;
		width: 80%;
	}

	/* VAULT PORTAL */
	.vault-portal {
		position: relative;
		width: 220px;
		height: 320px;
		background: #050505;
		border: 2px dashed #111;
		border-radius: 8px;
		cursor: pointer;
		transition: all 0.4s ease;
	}
	.vault-portal:hover { border-color: #222; background: #080808; transform: translateY(-5px); }

	.vault-inner {
		padding: 2rem;
		height: 100%;
		display: flex;
		flex-direction: column;
		justify-content: space-between;
	}
	.vault-id { font-family: var(--family-mono); font-size: 0.5rem; color: #222; letter-spacing: 0.1rem; }
	.vault-info-overlay { opacity: 0.3; transition: opacity 0.3s ease; }
	.vault-portal:hover .vault-info-overlay { opacity: 1; }
	.vault-info-overlay p { font-size: 0.6rem; color: #444; margin-bottom: 0.5rem; }
	.vault-info-overlay .sub { font-size: 0.45rem; color: #00ff88; font-family: var(--family-mono); }

	.close-vault { position: absolute; top: -10px; right: -10px; width: 24px; height: 24px; background: #ff4444; color: #fff; border: none; border-radius: 50%; cursor: pointer; display: none; }
	.vault-portal:hover .close-vault { display: block; }

	/* NODE SPIN (The Interface) */
	.node-spin-container {
		position: absolute;
		top: -20px;
		left: 40px;
		width: 280px;
		z-index: 100;
		animation: spin-up 0.6s cubic-bezier(0.16, 1, 0.3, 1);
	}

	@keyframes spin-up {
		from { opacity: 0; transform: translateY(20px) rotateY(-20deg); }
		to { opacity: 1; transform: translateY(0) rotateY(0); }
	}

	.stacked-card-anchor {
		width: 280px;
		position: relative;
	}

	/* CARD ARCHITECTURE */
	.node-card { width: 100%; min-height: 400px; perspective: 1000px; }
	.card-flipper { position: relative; width: 100%; height: 100%; transition: transform 0.8s cubic-bezier(0.16, 1, 0.3, 1); transform-style: preserve-3d; }
	.node-card.is-flipped .card-flipper { transform: rotateY(180deg); }
	.card-face { position: absolute; inset: 0; backface-visibility: hidden; background: #080808; border: 1px solid #222; border-radius: 4px; box-shadow: 0 30px 60px rgba(0,0,0,0.8); display: flex; flex-direction: column; }
	.card-back { transform: rotateY(180deg); background: #030303 !important; padding: 1.5rem; }

	.visual-viewport { height: 180px; overflow: hidden; background: #000; border-radius: 4px 4px 0 0; }
	img { width: 100%; height: 100%; object-fit: contain; opacity: 0.8; }
	.card-meta-container { padding: 1.2rem; flex: 1; display: flex; flex-direction: column; justify-content: space-between; }
	h3 { font-size: 0.9rem; color: #fff; margin: 0.4rem 0; }
	.diagnostic-tag { font-family: var(--family-mono); font-size: 0.45rem; color: #ff4444; font-weight: 900; }

	.analytics-footer { display: flex; justify-content: space-between; align-items: center; border-top: 1px solid #111; padding-top: 1rem; }
	.signal-meter { display: flex; gap: 2px; height: 8px; align-items: flex-end; }
	.signal-bar { width: 2px; background: #111; }
	.signal-bar.active { background: #00ff88; box-shadow: 0 0 5px #00ff88; }
	.score-value { font-size: 0.5rem; color: #444; font-family: var(--family-mono); }

	.action-group { display: flex; gap: 0.4rem; }
	.card-action { width: 26px; height: 26px; background: #111; border: 1px solid #222; color: #fff; cursor: pointer; border-radius: 50%; display: flex; align-items: center; justify-content: center; transition: all 0.2s ease; }
	.card-action:hover { background: #fff; color: #000; }
	.stack-trigger { border-radius: 4px; padding: 0 0.5rem; width: auto; font-size: 0.4rem; font-family: var(--family-mono); font-weight: 900; }

	/* BACK STYLES */
	.blueprint-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem; border-bottom: 1px solid #111; padding-bottom: 0.5rem; }
	.bp-label { font-family: var(--family-mono); font-size: 0.45rem; color: #333; }
	.spec-row { display: flex; justify-content: space-between; padding: 0.5rem 0; border-bottom: 1px solid #111; }
	.spec-row .label { font-size: 0.4rem; color: #222; }
	.spec-row .val { font-size: 0.4rem; color: #00ff88; font-family: var(--family-mono); }
	.blueprint-graph { flex: 1; margin: 1rem 0; background: #050505; border: 1px solid #111; position: relative; padding: 0.8rem; overflow: hidden; }
	.grid-mesh { position: absolute; inset: 0; background-image: linear-gradient(#111 1px, transparent 1px), linear-gradient(90deg, #111 1px, transparent 1px); background-size: 8px 8px; opacity: 0.3; }
	.blueprint-graph p { font-size: 0.5rem; color: #666; line-height: 1.4; position: relative; z-index: 2; font-family: var(--family-mono); }
	.buy-link-back { display: block; background: #fff; color: #000; text-align: center; padding: 0.8rem; font-size: 0.55rem; font-weight: 900; font-family: var(--family-mono); text-decoration: none; border-radius: 2px; }

	/* LAB DASHBOARD */
	.lab-dashboard { padding: 8rem 0 4rem 0; text-align: center; border-bottom: 1px solid #111; }
	.admin-subtitle { font-size: 0.6rem; letter-spacing: 0.3rem; color: #444; font-weight: 900; }
	h1 { font-size: 3rem; letter-spacing: -0.1rem; color: #fff; }
</style>
