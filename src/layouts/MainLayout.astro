---
import { ClientRouter } from 'astro:transitions';
import SetupSidebar from '../components/SetupSidebar.astro';
import HandoffOverlay from '../components/HandoffOverlay.astro';
const { title, description = "Curated High-Performance Creator Tools | THE MATTE BLACK STANDARD" } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<meta name="description" content={description} />
		
		<ClientRouter />
	</head>
	<body>
		<HandoffOverlay />
		<div class="grain-overlay"></div>
		<div class="vignette"></div>
		<div id="cursor"></div>
		
		<div class="matte-black-wrapper">
			<SetupSidebar />
			<nav>
				<div class="logo">SELECT<span class="highlight">STREAM</span></div>
				<div class="nav-links">
					<a href="/" class="curation-trigger">VAULT</a>
					<a href="/lab-notes">LAB_NOTES</a>
					<a href="/disclosure">PARTNERSHIP</a>
				</div>
			</nav>
			<main>
				<slot />
			</main>

			{/* THE CHECKOUT PORTAL (Merchant Node Interface) */}
			<div id="checkout-portal" class="checkout-overlay" style="display: none;">
				<div class="checkout-window">
					<div class="checkout-header">
						<span class="header-label">🔒 SECURE_ACQUISITION_CHANNEL</span>
						<button id="close-checkout" class="close-btn">&times;</button>
					</div>
					<div class="checkout-body">
						<div class="product-preview">
							<img id="checkout-img" src="" alt="" />
							<div class="product-info">
								<h2 id="checkout-title">NODE_TITLE</h2>
								<span id="checkout-price" class="price-tag">$0.00</span>
							</div>
						</div>
						<div class="checkout-form">
							<div class="input-group">
								<label>LICENSE_HOLDER_EMAIL</label>
								<input type="email" id="checkout-email" placeholder="engineer@lab.sovereign" autocomplete="off" />
							</div>
							<div class="gateway-selector">
								<button class="gateway-option active">STRIPE_SECURE</button>
								<button class="gateway-option">BITCOIN_LIGHTNING</button>
							</div>
							<button class="pay-btn" id="initiate-payment">INITIALIZE_TRANSACTION</button>
						</div>
					</div>
					<div class="checkout-footer">
						<p>By initializing, you agree to the SelectStream Digital License Agreement.</p>
					</div>
				</div>
			</div>

			<footer>
				<p>&copy; 2026 SelectStream Shop | THE MATTE BLACK STANDARD</p>
			</footer>
		</div>

		<script is:inline>
			const cursor = document.getElementById('cursor');
			document.addEventListener('mousemove', (e) => {
				cursor.style.left = e.clientX + 'px';
				cursor.style.top = e.clientY + 'px';
			});

			document.addEventListener('mousedown', () => cursor.style.transform = 'translate(-50%, -50%) scale(0.8)');
			document.addEventListener('mouseup', () => cursor.style.transform = 'translate(-50%, -50%) scale(1)');

			// Global Checkout Controller
			window.addEventListener('trigger-merchant-checkout', (e) => {
				const { title, price, image } = e.detail;
				const portal = document.getElementById('checkout-portal');
				if (!portal) return;

				document.getElementById('checkout-title').textContent = title.toUpperCase();
				document.getElementById('checkout-price').textContent = `$${price.toFixed(2)}`;
				document.getElementById('checkout-img').src = image;
				
				portal.style.display = 'flex';
				document.body.style.overflow = 'hidden';
				
				setTimeout(() => document.getElementById('checkout-email').focus(), 100);
			});

			document.getElementById('close-checkout')?.addEventListener('click', () => {
				document.getElementById('checkout-portal').style.display = 'none';
				document.body.style.overflow = '';
			});
		</script>
	</body>

	<style is:global>
	#cursor {
		position: fixed;
		width: 10px; height: 10px; background: #fff; border: 1px solid #00ff88; box-shadow: 0 0 10px rgba(0,255,136,0.3); border-radius: 50%; pointer-events: none; z-index: 1000000; mix-blend-mode: difference; transition: transform 0.1s ease; transform: translate(-50%, -50%);
	}

	.nav-links { display: flex; gap: 2rem; font-size: 0.6rem; letter-spacing: 0.2rem; font-weight: 900; }
	.nav-links a { color: #444; text-decoration: none; }
	.nav-links a:hover { color: #fff; }

	/* CHECKOUT STYLES */
	.checkout-overlay { position: fixed; inset: 0; background: rgba(0,0,0,0.9); backdrop-filter: blur(20px); z-index: 2000000; display: flex; align-items: center; justify-content: center; }
	.checkout-window { width: 450px; background: #050505; border: 1px solid #111; border-radius: 4px; box-shadow: 0 100px 200px rgba(0,0,0,1); overflow: hidden; }
	.checkout-header { padding: 1.5rem; border-bottom: 1px solid #111; display: flex; align-items: center; justify-content: space-between; }
	.header-label { font-family: var(--family-mono, monospace); font-size: 0.5rem; color: #444; letter-spacing: 0.2rem; }
	.close-btn { background: none; border: none; color: #333; font-size: 1.5rem; cursor: pointer; }
	
	.checkout-body { padding: 2.5rem; }
	.product-preview { display: flex; gap: 1.5rem; margin-bottom: 2.5rem; align-items: center; }
	#checkout-img { width: 80px; height: 80px; object-fit: contain; background: #000; border: 1px solid #111; border-radius: 2px; }
	.product-info h2 { font-size: 1.2rem; color: #fff; font-weight: 900; margin-bottom: 0.4rem; letter-spacing: -0.02rem; }
	.price-tag { font-family: var(--family-mono, monospace); color: #00ff88; font-size: 0.9rem; font-weight: 900; }

	.input-group label { font-family: var(--family-mono, monospace); font-size: 0.45rem; color: #333; display: block; margin-bottom: 0.8rem; letter-spacing: 0.1rem; }
	#checkout-email { width: 100%; background: #080808; border: 1px solid #111; padding: 1.2rem; color: #fff; font-family: var(--family-mono, monospace); font-size: 0.85rem; margin-bottom: 2rem; outline: none; border-radius: 2px; }
	#checkout-email:focus { border-color: #333; }

	.gateway-selector { display: flex; gap: 1rem; margin-bottom: 2rem; }
	.gateway-option { flex: 1; padding: 0.8rem; background: #080808; border: 1px solid #111; color: #444; font-size: 0.5rem; font-family: var(--family-mono, monospace); cursor: pointer; border-radius: 2px; }
	.gateway-option.active { border-color: #00ff88; color: #fff; background: #111; }

	.pay-btn { width: 100%; padding: 1.2rem; background: #fff; color: #000; border: none; font-family: var(--family-mono, monospace); font-size: 0.75rem; font-weight: 900; cursor: pointer; transition: all 0.3s ease; border-radius: 2px; }
	.pay-btn:hover { background: #00ff88; transform: translateY(-2px); }

	.checkout-footer { padding: 1.5rem; background: #030303; border-top: 1px solid #111; text-align: center; }
	.checkout-footer p { font-size: 0.4rem; color: #222; font-family: var(--family-mono, monospace); letter-spacing: 0.05rem; }

	:root {
		--bg-color: #030303;
		--text-color: #a0a0a0;
		--family-mono: 'Geist Mono', monospace;
	}

	* {
		box-sizing: border-box;
		margin: 0;
		padding: 0;
	}

	body {
		background-color: var(--bg-color);
		color: var(--text-color);
		font-family: 'Geist', sans-serif;
		overflow-x: hidden;
	}

	.matte-black-wrapper {
		min-height: 100vh;
		display: flex;
		flex-direction: column;
	}

	nav {
		height: 8rem;
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding: 0 4rem;
		border-bottom: 1px solid rgba(255,255,255,0.05);
	}

	.logo {
		font-size: 1.2rem;
		font-weight: 900;
		letter-spacing: 0.5rem;
		color: #fff;
	}

	.highlight {
		color: #666;
	}

	main {
		flex: 1;
		padding: 4rem;
	}

	footer {
		height: 10rem;
		display: flex;
		align-items: center;
		justify-content: center;
		border-top: 1px solid rgba(255,255,255,0.05);
	}

	footer p {
		font-size: 0.6rem;
		letter-spacing: 0.3rem;
		color: #222;
		font-weight: 900;
	}

	.grain-overlay {
		position: fixed;
		inset: 0;
		background-image: url("https://grainy-gradients.vercel.app/noise.svg");
		opacity: 0.03;
		pointer-events: none;
		z-index: 10000;
	}

	.vignette {
		position: fixed;
		inset: 0;
		background: radial-gradient(circle at center, transparent 0%, rgba(0,0,0,0.4) 100%);
		pointer-events: none;
		z-index: 5000;
	}
	</style>
</html>
